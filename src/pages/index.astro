---
import "../styles/global.css";

const youtubeFeedUrl =
  "https://www.youtube.com/feeds/videos.xml?channel_id=UCVI8LZ3goTC4QSy_t2qLVwQ";
const resumeUrl = "/Burce_Boran_Resume_2026.pdf";

const decodeXml = (value) =>
  value
    .replaceAll("&amp;", "&")
    .replaceAll("&quot;", '"')
    .replaceAll("&#39;", "'")
    .replaceAll("&lt;", "<")
    .replaceAll("&gt;", ">");

const getTagValue = (source, tagName) => {
  const escapedTag = tagName.replace(":", "\\:");
  const match = source.match(new RegExp(`<${escapedTag}[^>]*>([\\s\\S]*?)</${escapedTag}>`));
  return match ? decodeXml(match[1].trim()) : "";
};

const getThumbnailUrl = (source) => {
  const match = source.match(/<media:thumbnail[^>]*url="([^"]+)"/);
  return match ? decodeXml(match[1]) : "";
};

const getAlternateLink = (source) => {
  const match = source.match(/<link[^>]*rel="alternate"[^>]*href="([^"]+)"/);
  return match ? decodeXml(match[1]) : "";
};

const decodeHtml = (value) =>
  value
    .replaceAll("&amp;", "&")
    .replaceAll("&quot;", '"')
    .replaceAll("&#39;", "'")
    .replaceAll("&lt;", "<")
    .replaceAll("&gt;", ">")
    .replaceAll("&#x27;", "'")
    .replaceAll("&#x2F;", "/");

const formatPublishedDate = (value) =>
  new Intl.DateTimeFormat("en", {
    month: "short",
    day: "numeric",
    year: "numeric"
  }).format(new Date(value));

const fetchLatestVideos = async () => {
  try {
    const response = await fetch(youtubeFeedUrl);

    if (!response.ok) {
      throw new Error(`Feed request failed with ${response.status}`);
    }

    const xml = await response.text();

    return [...xml.matchAll(/<entry>([\s\S]*?)<\/entry>/g)].slice(0, 4).map(([, entry]) => ({
      id: getTagValue(entry, "yt:videoId"),
      title: getTagValue(entry, "title"),
      href: getAlternateLink(entry) || `https://www.youtube.com/watch?v=${getTagValue(entry, "yt:videoId")}`,
      publishedAt: formatPublishedDate(getTagValue(entry, "published")),
      thumbnail: getThumbnailUrl(entry)
    }));
  } catch (error) {
    console.error("Failed to load Arctic Latent videos", error);
    return [];
  }
};

const videos = await fetchLatestVideos();
const vimeoUrls = [
  "https://vimeo.com/1044521891",
  "https://vimeo.com/1090716436",
  "https://vimeo.com/424411862",
  "https://vimeo.com/299818240"
];
const vimeoLabels = [
  "VFX Demo Reel",
  "Unreal Environment Reel",
  "VFX Demo Reel 2",
  "VFX Demo Reel 3"
];
const vimeoUrl = vimeoUrls[0];
const imdbUrl = "https://www.imdb.com/name/nm9667865/";

const fetchVimeoData = async (url) => {
  try {
    const response = await fetch(
      `https://vimeo.com/api/oembed.json?url=${encodeURIComponent(url)}`
    );

    if (!response.ok) {
      throw new Error(`Vimeo request failed with ${response.status}`);
    }

    return response.json();
  } catch (error) {
    console.error("Failed to load Vimeo reel", url, error);
    return null;
  }
};

const vimeoReels = (await Promise.all(vimeoUrls.map((url) => fetchVimeoData(url)))).filter(Boolean);

const metacriticImageBase = "https://www.metacritic.com/a/img/catalog";
const metacriticSiteBase = "https://www.metacritic.com";

const fetchFilmography = async () => {
  const endpoints = [
    "https://backend.metacritic.com/people/metacritic/burce-boran/credits/web?productType=movie&componentName=credits&componentDisplayName=Credits&componentType=PersonList&sort=date",
    "https://backend.metacritic.com/people/metacritic/burce-boran/credits/web?productType=show&componentName=credits&componentDisplayName=Credits&componentType=PersonList&sort=date"
  ];

  try {
    const responses = await Promise.all(endpoints.map((url) => fetch(url).then((response) => response.json())));
    const items = responses.flatMap((payload) => payload?.data?.items ?? []);

    return items
      .map((item) => ({
        title: item.product.title,
        year: item.product.releaseYear,
        type: item.product.type === "show" ? "Series" : "Film",
        role: item.roles?.[0] ?? "",
        href: `${metacriticSiteBase}${item.product.url}`,
        image: item.product.image?.bucketPath
          ? `${metacriticImageBase}${item.product.image.bucketPath}`
          : ""
      }))
      .sort((left, right) => right.year - left.year);
  } catch (error) {
    console.error("Failed to load filmography", error);
    return [];
  }
};

const filmography = await fetchFilmography();
const githubUrl = "https://github.com/ArcticLatent";

const fetchPinnedRepos = async () => {
  try {
    const response = await fetch(githubUrl, {
      headers: {
        "User-Agent": "Mozilla/5.0"
      }
    });

    if (!response.ok) {
      throw new Error(`GitHub request failed with ${response.status}`);
    }

    const html = await response.text();
    const pinnedSectionMatch = html.match(
      /<div class="js-pinned-items-reorder-container">([\s\S]*?)<\/ol>/i
    );

    if (!pinnedSectionMatch) {
      return [];
    }

    const items = [...pinnedSectionMatch[1].matchAll(/<li[\s\S]*?<\/li>/g)].slice(0, 6);

    return items.map(([block]) => {
      const hrefMatch = block.match(/href="(\/ArcticLatent\/[^"]+)"/);
      const nameMatch = block.match(/<span class="repo">([\s\S]*?)<\/span>/);
      const descriptionMatch = block.match(/<p class="pinned-item-desc[\s\S]*?>([\s\S]*?)<\/p>/);
      const languageMatch = block.match(/<span itemprop="programmingLanguage">([\s\S]*?)<\/span>/);
      const languageColorMatch = block.match(/repo-language-color" style="background-color:\s*([^";]+)[^"]*"/);
      const starsMatch = block.match(/octicon-star[\s\S]*?<\/svg>\s*([0-9]+)/);

      return {
        name: decodeHtml((nameMatch?.[1] ?? "").trim()),
        href: hrefMatch ? `https://github.com${hrefMatch[1]}` : githubUrl,
        description: decodeHtml((descriptionMatch?.[1] ?? "").replace(/<[^>]+>/g, "").trim()),
        language: decodeHtml((languageMatch?.[1] ?? "").trim()),
        languageColor: (languageColorMatch?.[1] ?? "#93f5d8").trim(),
        stars: (starsMatch?.[1] ?? "").trim()
      };
    });
  } catch (error) {
    console.error("Failed to load GitHub pinned repos", error);
    return [];
  }
};

const pinnedRepos = await fetchPinnedRepos();
const defaultHeadline = "A focused hub for the work I make, teach, and build.";
const siteUrl = "https://burceboran.ca";
const pageTitle = "Burce Boran | Asset Supervisor, VFX, AI Workflows";
const pageDescription =
  "Burce Boran is an Asset Supervisor sharing VFX work, film and television credits, AI workflows, ComfyUI education, GitHub projects, and creative technology experiments.";
const canonicalUrl = `${siteUrl}/`;
const ogImageUrl = `${siteUrl}/og-image.svg`;
const faviconUrl = `${siteUrl}/favicon.svg`;
const ledeText =
  "Asset supervision, VFX, AI workflows, ComfyUI education, and creative technology in one place.";
const socialLinks = [
  "https://www.linkedin.com/in/burceboran/",
  "https://github.com/ArcticLatent",
  "https://www.youtube.com/@ArcticLatent",
  "https://vimeo.com/1044521891",
  "https://www.imdb.com/name/nm9667865/"
];
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Burce Boran",
  url: siteUrl,
  jobTitle: "Asset Supervisor",
  description: pageDescription,
  sameAs: socialLinks,
  knowsAbout: [
    "Visual Effects",
    "Asset Supervision",
    "3D Assets",
    "Texturing",
    "AI Workflows",
    "ComfyUI",
    "Creative Technology"
  ]
};
const websiteStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Burce Boran",
  url: siteUrl,
  description: pageDescription,
  author: {
    "@type": "Person",
    name: "Burce Boran"
  }
};
const collectionStructuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Burce Boran",
  url: canonicalUrl,
  description: pageDescription,
  about: {
    "@type": "Person",
    name: "Burce Boran"
  },
  hasPart: [
    ...vimeoUrls.map((url, index) => ({
      "@type": "VideoObject",
      name: vimeoLabels[index] ?? `VFX Demo Reel ${index + 1}`,
      url
    })),
    {
      "@type": "CreativeWork",
      name: "Arctic Latent",
      url: "https://www.youtube.com/@ArcticLatent"
    },
    {
      "@type": "ProfilePage",
      name: "IMDb Filmography",
      url: imdbUrl
    },
    {
      "@type": "ProfilePage",
      name: "GitHub",
      url: githubUrl
    },
    {
      "@type": "ProfilePage",
      name: "LinkedIn",
      url: "https://www.linkedin.com/in/burceboran/"
    }
  ]
};
const aboutParagraphs = [
  `Asset Supervisor with 15+ years of experience across design, visual effects, film, and television. Experienced in leading asset teams, improving workflows, and delivering high-quality 3D assets and textures for film and television.`,
  `Known for mentoring artists, coaching teams, teaching practical workflows, and creating supportive environments where people can grow while delivering strong production results.`,
  `Credits include Final Destination: Bloodlines, Borderlands, Avatar: The Last Airbender (8 episodes, all 3 seasons), Goliath (10 episodes), The Mandalorian (4 episodes), Star Trek: Discovery (21 episodes), Carnival Row (8 episodes), Colony (6 episodes), See (1 episode), The Stand (1 episode), Midway, and Goosebumps 2: Haunted Halloween.`,
  `Alongside that production background, brings strong curiosity for new AI tools and emerging technology, now applying that mindset to AI workflow design, ComfyUI education, and creator tooling with a focus on practical systems, knowledge sharing, and artist-friendly pipelines.`
];

const links = [
  {
    label: "About Me",
    href: "#",
    note: "Background, credits, and focus",
    variant: "about",
    icon: "about"
  },
  {
    label: "VFX Demo Reel",
    href: vimeoUrl,
    note: "Selected professional work",
    variant: "vimeo",
    icon: "reel"
  },
  {
    label: "Arctic Latent",
    href: "https://www.youtube.com/@ArcticLatent",
    note: "ComfyUI and AI tutorials",
    variant: "youtube",
    icon: "youtube"
  },
  {
    label: "Filmography",
    href: imdbUrl,
    note: "Credits and production work",
    icon: "film"
  },
  {
    label: "GitHub",
    href: githubUrl,
    note: "Code, builds, and tools",
    icon: "github"
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/burceboran/",
    note: "Professional profile and experience",
    icon: "linkedin"
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="author" content="Burce Boran" />
    <meta name="keywords" content="Burce Boran, Asset Supervisor, VFX, AI workflows, ComfyUI, creative technology, filmography, GitHub, Vimeo, YouTube" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Burce Boran" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="Burce Boran website preview" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="theme-color" content="#07111a" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(collectionStructuredData)}></script>
  </head>
  <body>
    <div class="page-shell">
      <div class="geometry-layer" aria-hidden="true">
        <canvas class="geometry-canvas"></canvas>
      </div>
      <div class="ambient ambient-one"></div>
      <div class="ambient ambient-two"></div>
      <div class="grid-glow"></div>

      <main class="hero">
        <section class="intro">
          <button class="identity-mark" type="button" aria-label="Reload homepage" data-home-trigger>
            <p class="eyebrow eyebrow-shadow" aria-hidden="true">Burce Boran</p>
            <p class="eyebrow eyebrow-main">Burce Boran</p>
          </button>
          <div class="headline-switcher" data-headline>
            <h1 class="headline-panel headline-default">{defaultHeadline}</h1>
            <div class="headline-panel headline-about" aria-hidden="true">
              <div class="headline-about-body">
                <div class="headline-about-copy">
                  {aboutParagraphs.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
                <p class="about-resume-link">
                  <a href={resumeUrl} target="_blank" rel="noreferrer">View resume</a>
                </p>
              </div>
            </div>
          </div>
          <p class="lede" data-lede>
            {ledeText}
          </p>
        </section>

        <section class="links-panel" aria-label="Primary links" style={`--link-count:${links.length};`}>
          {links.map((link, index) => (
            link.variant === "about" || link.variant === "youtube" || link.variant === "vimeo" || link.label === "Filmography" || link.label === "GitHub" ? (
              <button
                class="link-card link-card-button"
                type="button"
                data-showcase-toggle={link.variant !== "about" ? true : undefined}
                data-about-toggle={link.variant === "about" ? true : undefined}
                data-target={link.variant === "youtube"
                  ? "youtube-videos"
                  : link.variant === "vimeo"
                    ? "vimeo-reel"
                    : link.label === "Filmography"
                      ? "filmography-projects"
                      : "github-projects"}
                aria-expanded={link.variant === "about" ? undefined : "false"}
                aria-controls={link.variant === "youtube"
                  ? "youtube-videos"
                  : link.variant === "vimeo"
                    ? "vimeo-reel"
                    : link.label === "Filmography"
                      ? "filmography-projects"
                      : "github-projects"}
                style={`--delay:${index};`}
              >
                <span class="link-label">
                  <span class={`link-icon link-icon-${link.icon}`} aria-hidden="true">
                    {link.icon === "about" ? (
                      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <circle cx="12" cy="7.5" r="2.5"></circle>
                        <path d="M6.5 18c1.2-3 3.15-4.5 5.5-4.5S16.3 15 17.5 18"></path>
                      </svg>
                    ) : link.icon === "reel" ? (
                      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <rect x="4" y="6" width="16" height="12" rx="2.5"></rect>
                        <path d="M8 6l2.5 4"></path>
                        <path d="M13.5 6l2.5 4"></path>
                        <path d="M8 18l2.5-4"></path>
                        <path d="M13.5 18l2.5-4"></path>
                      </svg>
                    ) : link.icon === "youtube" ? (
                      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <rect x="3.5" y="6" width="17" height="12" rx="4"></rect>
                        <path d="M10 9.25L15 12l-5 2.75z"></path>
                      </svg>
                    ) : link.icon === "film" ? (
                      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <path d="M6.5 7.5h11"></path>
                        <path d="M6.5 12h11"></path>
                        <path d="M6.5 16.5h11"></path>
                        <path d="M4.5 7.5h.01"></path>
                        <path d="M4.5 12h.01"></path>
                        <path d="M4.5 16.5h.01"></path>
                      </svg>
                    ) : link.icon === "github" ? (
                      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <path d="M9 18c-3.5 1-3.5-2-5-2"></path>
                        <path d="M15 21v-2.5a2.2 2.2 0 0 0-.65-1.65c2.15-.24 4.4-1.06 4.4-4.8a3.74 3.74 0 0 0-1-2.6 3.48 3.48 0 0 0-.06-2.57s-.82-.26-2.69 1a9.25 9.25 0 0 0-5 0c-1.87-1.26-2.69-1-2.69-1a3.48 3.48 0 0 0-.06 2.57 3.74 3.74 0 0 0-1 2.6c0 3.71 2.25 4.53 4.4 4.8A2.2 2.2 0 0 0 9 18.5V21"></path>
                      </svg>
                    ) : (
                      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <path d="M7 9v8"></path>
                        <path d="M7 6.5h.01"></path>
                        <path d="M11 17V9"></path>
                        <path d="M11 11.5c.6-1.35 1.8-2.5 3.9-2.5 2.6 0 4.1 1.7 4.1 4.9V17"></path>
                      </svg>
                    )}
                  </span>
                  <span>{link.label}</span>
                </span>
                <span class="link-note">{link.note}</span>
              </button>
            ) : (
              <a class="link-card" href={link.href} target="_blank" rel="noreferrer" style={`--delay:${index};`}>
                <span class="link-label">
                  <span class={`link-icon link-icon-${link.icon}`} aria-hidden="true">
                    {link.icon === "linkedin" ? (
                      <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                        <path d="M7 9v8"></path>
                        <path d="M7 6.5h.01"></path>
                        <path d="M11 17V9"></path>
                        <path d="M11 11.5c.6-1.35 1.8-2.5 3.9-2.5 2.6 0 4.1 1.7 4.1 4.9V17"></path>
                      </svg>
                    ) : null}
                  </span>
                  <span>{link.label}</span>
                </span>
                <span class="link-note">{link.note}</span>
              </a>
            )
          ))}
        </section>
      </main>

      <section
        class:list={["video-showcase", videos.length > 0 && "video-showcase-ready"]}
        id="youtube-videos"
        aria-label="Latest Arctic Latent videos"
        hidden
      >
        <div class="showcase-header">
          <p class="showcase-kicker">Latest from Arctic Latent</p>
          <a class="showcase-link" href="https://www.youtube.com/@ArcticLatent" target="_blank" rel="noreferrer">
            Open channel
          </a>
        </div>

        {videos.length > 0 ? (
          <div class="video-grid">
            {videos.map((video) => (
              <a class="video-card" href={video.href} target="_blank" rel="noreferrer">
                <div class="video-thumb-wrap">
                  <img
                    class="video-thumb"
                    src={video.thumbnail}
                    alt={`Thumbnail for ${video.title}`}
                    loading="lazy"
                  />
                </div>
                <div class="video-meta">
                  <p class="video-date">{video.publishedAt}</p>
                  <h2>{video.title}</h2>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <p class="video-fallback">
            Latest uploads are temporarily unavailable. Visit the
            <a href="https://www.youtube.com/@ArcticLatent" target="_blank" rel="noreferrer"> Arctic Latent channel</a>.
          </p>
        )}
      </section>

      <section
        class="video-showcase github-showcase"
        id="github-projects"
        aria-label="Pinned GitHub repositories"
        hidden
      >
        <div class="showcase-header">
          <p class="showcase-kicker">Pinned Repositories</p>
          <a class="showcase-link" href={githubUrl} target="_blank" rel="noreferrer">
            Open GitHub
          </a>
        </div>

        {pinnedRepos.length > 0 ? (
          <div class="repo-grid">
            {pinnedRepos.map((repo, index) => (
              <a class="repo-card" href={repo.href} target="_blank" rel="noreferrer" style={`--repo-accent:${repo.languageColor}; --repo-index:${index};`}>
                <div class="repo-thumb">
                  <div class="repo-thumb-noise"></div>
                  <p class="repo-thumb-label">{repo.language || "Repository"}</p>
                  <h2>{repo.name}</h2>
                </div>
                <div class="repo-meta">
                  <p>{repo.description || "Open repository on GitHub."}</p>
                  <div class="repo-stats">
                    {repo.language ? (
                      <span class="repo-pill">
                        <span class="repo-pill-dot" style={`--dot:${repo.languageColor};`}></span>
                        {repo.language}
                      </span>
                    ) : null}
                    {repo.stars ? <span class="repo-pill">{repo.stars} stars</span> : null}
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <p class="video-fallback">
            Pinned repositories are temporarily unavailable here. Visit
            <a href={githubUrl} target="_blank" rel="noreferrer"> GitHub</a>.
          </p>
        )}
      </section>

      <section
        class="video-showcase filmography-showcase"
        id="filmography-projects"
        aria-label="Filmography projects"
        hidden
      >
        <div class="showcase-header">
          <p class="showcase-kicker">Selected Filmography</p>
          <a class="showcase-link" href={imdbUrl} target="_blank" rel="noreferrer">
            Open IMDb
          </a>
        </div>

        {filmography.length > 0 ? (
          <div class="film-grid">
            {filmography.map((project) => (
              <a class="film-card" href={project.href} target="_blank" rel="noreferrer">
                <div class="film-poster-wrap">
                  {project.image ? (
                    <img
                      class="film-poster"
                      src={project.image}
                      alt={`Poster for ${project.title}`}
                      loading="lazy"
                    />
                  ) : (
                    <div class="film-poster film-poster-fallback"></div>
                  )}
                </div>
                <div class="film-meta">
                  <p class="film-overline">{project.type} • {project.year}</p>
                  <h2>{project.title}</h2>
                  <p>{project.role}</p>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <p class="video-fallback">
            Filmography is temporarily unavailable here. Visit
            <a href={imdbUrl} target="_blank" rel="noreferrer"> IMDb</a>.
          </p>
        )}
      </section>

      <section
        class="video-showcase reel-showcase"
        id="vimeo-reel"
        aria-label="VFX demo reel"
        hidden
      >
        <div class="showcase-header">
          <p class="showcase-kicker">Selected Reels</p>
        </div>

        {vimeoReels.length > 0 ? (
          <div class="reel-grid">
            {vimeoReels.map((reel, index) => (
              <article class="reel-card">
                <div class="reel-card-header">
                  <p class="reel-title">{vimeoLabels[index] ?? `VFX Demo Reel ${index + 1}`}</p>
                  <a class="showcase-link" href={vimeoUrls[index]} target="_blank" rel="noreferrer">
                    Open on Vimeo
                  </a>
                </div>
                <div class="reel-layout">
                  <div class="reel-player">
                    <iframe
                      src={`https://player.vimeo.com/video/${reel.video_id}?title=0&byline=0&portrait=0`}
                      title={reel.title}
                      loading="lazy"
                      allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
                      allowfullscreen
                    ></iframe>
                  </div>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p class="video-fallback">
            The reel is temporarily unavailable here. Watch it on
            <a href={vimeoUrl} target="_blank" rel="noreferrer"> Vimeo</a>.
          </p>
        )}
      </section>

    </div>

    <div class="back-to-top-wrap">
      <button class="back-to-top" type="button" aria-label="Move to top" data-back-to-top>
        <span class="back-to-top-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="presentation" focusable="false">
            <path d="M12 19V6"></path>
            <path d="M6.75 11.25L12 6l5.25 5.25"></path>
          </svg>
        </span>
        Top
      </button>
    </div>

    <script is:inline>
      const canvas = document.querySelector(".geometry-canvas");
      const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
      const showcaseToggles = [...document.querySelectorAll("[data-showcase-toggle]")];
      const aboutToggle = document.querySelector("[data-about-toggle]");
      const showcases = [...document.querySelectorAll(".video-showcase")];
      const backToTopButton = document.querySelector("[data-back-to-top]");
      const backToTopWrap = document.querySelector(".back-to-top-wrap");
      const headline = document.querySelector("[data-headline]");
      const homeTrigger = document.querySelector("[data-home-trigger]");
      const lede = document.querySelector("[data-lede]");
      const intro = document.querySelector(".intro");
      const linksPanel = document.querySelector(".links-panel");
      let introHeightLocked = false;
      let lastViewportWidth = window.innerWidth;
      let lastIsDesktopViewport = window.innerWidth >= 860;

      const syncColumnHeights = () => {
        if (!intro || !linksPanel || window.innerWidth < 860) {
          document.documentElement.style.removeProperty("--intro-block-height");
          introHeightLocked = false;
          return;
        }

        if (introHeightLocked) {
          return;
        }

        document.documentElement.style.setProperty("--intro-block-height", `${intro.offsetHeight}px`);
        introHeightLocked = true;
      };

      const setAboutMode = (enabled) => {
        headline?.classList.toggle("is-about", enabled);
        aboutToggle?.classList.toggle("is-active", enabled);
        lede?.classList.toggle("is-hidden", enabled);
      };

      if (headline && aboutToggle) {
        aboutToggle.addEventListener("click", () => {
          const nextState = !aboutToggle.classList.contains("is-active");

          showcaseToggles.forEach((button) => {
            button.setAttribute("aria-expanded", "false");
          });

          showcases.forEach((section) => {
            section.hidden = true;
            section.classList.remove("is-visible");
          });

          setAboutMode(nextState);
        });
      }

      if (homeTrigger) {
        homeTrigger.addEventListener("click", () => {
          window.location.reload();
        });
      }

      showcaseToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          setAboutMode(false);

          const targetId = toggle.dataset.target;
          const target = targetId ? document.getElementById(targetId) : null;
          const isOpen = toggle.getAttribute("aria-expanded") === "true";

          if (target && isOpen) {
            target.hidden = false;
            target.classList.add("is-visible");
            target.scrollIntoView({ behavior: "smooth", block: "start" });
            return;
          }

          showcaseToggles.forEach((button) => {
            button.setAttribute("aria-expanded", "false");
          });

          showcases.forEach((section) => {
            section.hidden = true;
            section.classList.remove("is-visible");
          });

          if (target) {
            toggle.setAttribute("aria-expanded", "true");
            target.hidden = false;
            target.classList.add("is-visible");
            target.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        });
      });

      if (backToTopButton) {
        const syncBackToTopMode = () => {
          const hasVisibleShowcase = showcases.some((section) => section.classList.contains("is-visible"));
          const wrapTop = backToTopWrap ? backToTopWrap.getBoundingClientRect().top : 0;
          const shouldFloat = hasVisibleShowcase && wrapTop > window.innerHeight - 96;

          backToTopButton.classList.toggle("is-floating", shouldFloat);
        };

        const syncVisibleShowcaseLayout = () => {
          const visibleShowcase = showcases.find((section) => section.classList.contains("is-visible"));

          if (!visibleShowcase) {
            return;
          }

          const showcaseTop = visibleShowcase.getBoundingClientRect().top;
          const targetTop = 24;

          if (Math.abs(showcaseTop - targetTop) > 32) {
            const nextScrollTop = window.scrollY + showcaseTop - targetTop;
            window.scrollTo({ top: Math.max(0, nextScrollTop), behavior: "auto" });
          }
        };

        const syncBackToTop = () => {
          backToTopButton.classList.toggle("is-visible", window.scrollY > 180);
          syncBackToTopMode();
        };

        syncBackToTopMode();
        syncBackToTop();
        syncColumnHeights();
        window.addEventListener("scroll", syncBackToTop, { passive: true });
        window.addEventListener("resize", () => {
          const nextViewportWidth = window.innerWidth;
          const nextIsDesktopViewport = nextViewportWidth >= 860;
          const crossedDesktopBreakpoint = nextIsDesktopViewport !== lastIsDesktopViewport;
          const widthChangedEnough = Math.abs(nextViewportWidth - lastViewportWidth) > 80;

          introHeightLocked = false;

          if (nextIsDesktopViewport && (crossedDesktopBreakpoint || widthChangedEnough)) {
            syncVisibleShowcaseLayout();
          }

          syncBackToTop();
          syncColumnHeights();
          lastViewportWidth = nextViewportWidth;
          lastIsDesktopViewport = nextIsDesktopViewport;
        });
        backToTopButton.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });

        showcaseToggles.forEach((toggle) => {
          toggle.addEventListener("click", () => {
            const targetId = toggle.dataset.target;
            const target = targetId ? document.getElementById(targetId) : null;
            const shouldOpen = toggle.getAttribute("aria-expanded") === "true";

            requestAnimationFrame(() => {
              if (shouldOpen && target) {
                target.scrollIntoView({ behavior: "smooth", block: "start" });
              }

              syncBackToTop();
            });
          });
        });
      }

      syncColumnHeights();

      if (canvas && !mediaQuery.matches) {
        const context = canvas.getContext("2d");
        const points = [];
        const pointCount = 36;
        const palette = {
          line: "rgba(202, 231, 255, 0.22)",
          glow: "rgba(147, 245, 216, 0.12)",
          point: "rgba(240, 185, 134, 0.85)"
        };

        let width = 0;
        let height = 0;
        let centerX = 0;
        let centerY = 0;
        let shapeTimer = 0;
        let shapePhase = "drift";
        let phaseDuration = 220;
        let frameHandle = 0;
        let lastTime = 0;

        const randomBetween = (min, max) => min + Math.random() * (max - min);

        const createPoint = () => ({
          x: 0,
          y: 0,
          vx: randomBetween(-0.35, 0.35),
          vy: randomBetween(-0.35, 0.35),
          driftX: Math.random() * Math.PI * 2,
          driftY: Math.random() * Math.PI * 2,
          targetX: null,
          targetY: null
        });

        const resize = () => {
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          width = window.innerWidth;
          height = window.innerHeight;
          centerX = width / 2;
          centerY = height / 2;

          canvas.width = Math.round(width * dpr);
          canvas.height = Math.round(height * dpr);
          canvas.style.width = `${width}px`;
          canvas.style.height = `${height}px`;
          context.setTransform(dpr, 0, 0, dpr, 0, 0);

          if (points.length === 0) {
            for (let index = 0; index < pointCount; index += 1) {
              points.push(createPoint());
            }
          }

          for (const point of points) {
            if (point.x === 0 && point.y === 0) {
              point.x = randomBetween(0, width);
              point.y = randomBetween(0, height);
            } else {
              point.x = Math.min(Math.max(point.x, 0), width);
              point.y = Math.min(Math.max(point.y, 0), height);
            }
          }
        };

        const sampleEdges = (vertices, totalPoints) => {
          const sampled = [];

          for (let index = 0; index < totalPoints; index += 1) {
            const edgeIndex = index % vertices.length;
            const nextIndex = (edgeIndex + 1) % vertices.length;
            const step = (index / totalPoints) * vertices.length;
            const t = step - Math.floor(step);
            const start = vertices[edgeIndex];
            const end = vertices[nextIndex];

            sampled.push({
              x: start.x + (end.x - start.x) * t,
              y: start.y + (end.y - start.y) * t
            });
          }

          return sampled;
        };

        const createVertices = () => {
          const radius = Math.min(width, height) * randomBetween(0.14, 0.24);
          const offsetX = centerX + randomBetween(-width * 0.18, width * 0.18);
          const offsetY = centerY + randomBetween(-height * 0.16, height * 0.16);
          const rotation = randomBetween(0, Math.PI * 2);
          const shapes = [
            { sides: 3, wobble: 1 },
            { sides: 4, wobble: 0.72 },
            { sides: 5, wobble: 1 },
            { sides: 6, wobble: 0.82 },
            { sides: 8, wobble: 0.54 }
          ];
          const shape = shapes[Math.floor(Math.random() * shapes.length)];

          return Array.from({ length: shape.sides }, (_, index) => {
            const angle = rotation + (Math.PI * 2 * index) / shape.sides;
            const modulation = index % 2 === 0 ? 1 : shape.wobble;

            return {
              x: offsetX + Math.cos(angle) * radius * modulation,
              y: offsetY + Math.sin(angle) * radius * modulation
            };
          });
        };

        const setShapeTargets = () => {
          const vertices = createVertices();
          const targets = sampleEdges(vertices, points.length);

          points.forEach((point, index) => {
            point.targetX = targets[index].x;
            point.targetY = targets[index].y;
          });
        };

        const clearTargets = () => {
          for (const point of points) {
            point.targetX = null;
            point.targetY = null;
          }
        };

        const updatePhase = () => {
          shapeTimer += 1;

          if (shapeTimer < phaseDuration) {
            return;
          }

          shapeTimer = 0;

          if (shapePhase === "drift") {
            shapePhase = "shape";
            phaseDuration = 160;
            setShapeTargets();
            return;
          }

          shapePhase = "drift";
          phaseDuration = 220;
          clearTargets();
        };

        const updatePoints = (timeFactor) => {
          points.forEach((point, index) => {
            point.driftX += 0.006 * timeFactor;
            point.driftY += 0.004 * timeFactor;

            if (point.targetX !== null && point.targetY !== null) {
              point.x += (point.targetX - point.x) * 0.05 * timeFactor;
              point.y += (point.targetY - point.y) * 0.05 * timeFactor;
              return;
            }

            point.vx += Math.sin(point.driftX + index) * 0.0035 * timeFactor;
            point.vy += Math.cos(point.driftY + index) * 0.0035 * timeFactor;
            point.vx *= 0.992;
            point.vy *= 0.992;

            point.x += point.vx * timeFactor;
            point.y += point.vy * timeFactor;

            if (point.x < -40) point.x = width + 40;
            if (point.x > width + 40) point.x = -40;
            if (point.y < -40) point.y = height + 40;
            if (point.y > height + 40) point.y = -40;
          });
        };

        const draw = () => {
          context.clearRect(0, 0, width, height);

          for (let index = 0; index < points.length; index += 1) {
            const point = points[index];

            for (let next = index + 1; next < points.length; next += 1) {
              const other = points[next];
              const dx = other.x - point.x;
              const dy = other.y - point.y;
              const distance = Math.hypot(dx, dy);
              const maxDistance = shapePhase === "shape" ? 180 : 120;

              if (distance > maxDistance) {
                continue;
              }

              const opacity = 1 - distance / maxDistance;
              context.strokeStyle = `rgba(202, 231, 255, ${opacity * (shapePhase === "shape" ? 0.4 : 0.18)})`;
              context.lineWidth = shapePhase === "shape" ? 1.2 : 0.85;
              context.beginPath();
              context.moveTo(point.x, point.y);
              context.lineTo(other.x, other.y);
              context.stroke();
            }
          }

          for (const point of points) {
            context.fillStyle = palette.glow;
            context.beginPath();
            context.arc(point.x, point.y, shapePhase === "shape" ? 3.4 : 2.5, 0, Math.PI * 2);
            context.fill();

            context.fillStyle = palette.point;
            context.beginPath();
            context.arc(point.x, point.y, 1.05, 0, Math.PI * 2);
            context.fill();
          }
        };

        const animate = (time) => {
          const delta = Math.min((time - lastTime) / 16.6667 || 1, 2);
          lastTime = time;

          updatePhase();
          updatePoints(delta);
          draw();
          frameHandle = window.requestAnimationFrame(animate);
        };

        const stop = () => {
          window.cancelAnimationFrame(frameHandle);
        };

        resize();
        setShapeTargets();
        shapePhase = "shape";
        phaseDuration = 150;
        frameHandle = window.requestAnimationFrame(animate);

        window.addEventListener("resize", resize);
        window.addEventListener("beforeunload", stop, { once: true });
      }
    </script>
  </body>
</html>
